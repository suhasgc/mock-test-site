        "20007": {
            "id": "20007",
            "marks": 3,
            "negative_marks": 0.0,
            "is_input_type": true,
            "is_multi_select": false,
            "instructions": "",
            "question_text": "Due to a man leaving the group of 6 people, the average weight of the group drops from 63 to 60. Find the weight of the man who left the group? <ul class='list-group'> <li class='list-group-item'><B><a href='#quesSol1576350' data-toggle='collapse' aria-expanded='true'> Answer key/Solution</a></B></li> </ul>",
            "options": [],
            "correct_response": [
                [
                    "78"
                ]
            ],
            "solution": "<div><B>Solution: <br>Correct\n\t\t\t\t\t\t\t\tAnswer : <b>78</B>\n\t\t\t\t\t\t\t\t<div><b>Let every person has Rs. 1 coins equivalent to their weight. While leaving, this\n\t\t\t\t\t\t\t\t\t\tperson took away 63 coins of his own\n\t\t\t\t\t\t\t\t\t\tplus 3 coins from each of the remaining 5 individuals.<br>\n\t\t\t\t\t\t\t\t\t\tSo, weight = number of coins he had = 63 + 5 \u00d7 3 = 78.</div></div>"
        },
        "20008": {
            "id": "20008",
            "marks": 3,
